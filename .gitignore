# ===== doom-ng .gitignore =====
# Source-only repo: every DOOM/id-derived asset is GENERATED from your own doom1.wad
# at build time and must NEVER be committed. Copyrighted Neo Geo BIOS firmware likewise.

# --- Build outputs / intermediates ---
build/
*.o
*.elf
*.ihx
*.pal
*.bin
doomng-host
doomng-host-fixed
# machine-specific toolchain config (auto-bootstrapped from config.mk.SAMPLE)
neogeo/config.mk
neogeo/setup/

# --- Neo Geo C-ROM / fix-layer tiles (generated) ---
*.c1
*.c2
*.fix
*.crom
# EXCEPTION: ngdevkit's own freely-licensed base art (logo sprite + fix-layer font) is
# NOT DOOM/id content and MUST ship so a fresh clone can link the cart. Re-include it
# past the *.c1/*.c2/*.fix rules above. (Regenerate via ngdevkit-examples
# 00-template/setup/ngdevkit-assets.)
!neogeo/assets/prebuilt/
!neogeo/assets/prebuilt/base-crom-logo.c1
!neogeo/assets/prebuilt/base-crom-logo.c2
!neogeo/assets/prebuilt/base-srom-text-shadow.fix

# --- Images / debug dumps (generated) ---
*.bmp
*.png
neogeo/assets/logo.gif

# --- id Software IWAD — bring your own; never redistributed here ---
*.wad

# --- Copyrighted Neo Geo BIOS firmware (SNK) + all packaged zips ---
# A source-only repo tracks NO .zip (BIOS, gngeo datafile, MAME romset).
*.zip
neogeo.zip
aes.zip
*.sp1
*.sfix

# --- Python bytecode ---
__pycache__/
*.pyc

# --- macOS ---
.DS_Store

# --- Generated audio (from your WAD; the music is also copyright) ---
*.adpcmb
neogeo/snd_*.adpcma
neogeo/snd_*.wav
midi/
neogeo/midi/

# --- Generated headers + data (regenerated from doom1.wad by `make rom-vs`) ---
# NEVER commit — this would redistribute id Software content.
src/map.c
neogeo/textiles.h
neogeo/ramps.h
neogeo/ceillut.h
neogeo/titlepic.h
neogeo/texpal.h
neogeo/menu.h
neogeo/vs_e1.h
neogeo/vsflat.h
neogeo/sprites.h
neogeo/hudfix.h
neogeo/gunhand.h
neogeo/floorlut.h
neogeo/vsfloor.h
neogeo/vsceil.h
neogeo/nodes_data.h
neogeo/nodes_data.c
neogeo/nodes_idx.c
neogeo/gngeo_data_doomng.zip
neogeo/tools/gngeo-dor
tools/gngeo-shot/
flat_gallery/*.png
path_nodes.txt
ramps_used.txt
dist/
